# ============================================================
#  Atlas — environment template.
#  Copy this to ".env" and fill in your real keys:
#     Copy-Item .env.example .env     (Windows PowerShell)
#     cp .env.example .env            (macOS / Linux)
#  The real .env is gitignored and must NEVER be committed.
# ============================================================

# --- Which LLM Atlas uses (swappable without touching code) ---
# Provider: google | openai | anthropic
LLM_PROVIDER=google
# Model id for the chosen provider:
#   google    -> gemini-2.5-flash
#   openai    -> gpt-4o-mini
#   anthropic -> claude-sonnet-4-6
LLM_MODEL=gemini-2.5-flash
# 0.0 = focused/factual, 1.0 = creative. Research wants it low.
LLM_TEMPERATURE=0.2

# --- API keys (fill in the ones you actually use) ---
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Web search (required from Phase 1) ---
TAVILY_API_KEY=

# --- Langfuse tracing (Phase 4; optional until then) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Atlas behavior knobs ---
# Hard safety cap so the supervisor loop can never run forever.
ATLAS_MAX_ITERATIONS=6
# How many results Tavily returns per search.
TAVILY_MAX_RESULTS=5

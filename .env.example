# ============================================================
#  Atlas — environment template.
#  Copy this to ".env" and fill in your real keys:
#     Copy-Item .env.example .env     (Windows PowerShell)
#     cp .env.example .env            (macOS / Linux)
#  The real .env is gitignored and must NEVER be committed.
# ============================================================

# --- Which LLM Atlas uses (swappable without touching code) ---
# Provider: google | openai | anthropic
LLM_PROVIDER=google
# Model id for the chosen provider:
#   google    -> gemini-2.5-flash
#   openai    -> gpt-4o-mini
#   anthropic -> claude-sonnet-4-6
LLM_MODEL=gemini-2.5-flash
# 0.0 = focused/factual, 1.0 = creative. Research wants it low.
LLM_TEMPERATURE=0.2

# --- Gemini API key pool ---
# Atlas ROTATES across every Gemini key it finds: round-robin per call, plus
# automatic failover when a key hits its free-tier rate limit. Add as many as
# you have. Use keys from DIFFERENT Google projects/accounts — keys in the same
# project share one quota, so duplicates there won't add throughput.
GOOGLE_API_KEY=
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
# ...add GEMINI_API_KEY_4, _5, ... for as many keys as you have.

# --- Other providers (only used if you switch LLM_PROVIDER) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Web search (required from Phase 1) ---
TAVILY_API_KEY=

# --- Langfuse tracing (Phase 4; optional until then) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Atlas behavior knobs ---
# Hard safety cap so the supervisor loop can never run forever.
ATLAS_MAX_ITERATIONS=6
# How many results Tavily returns per search.
TAVILY_MAX_RESULTS=5
